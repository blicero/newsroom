{{ define "histogram" }}
{{/* Created on 05. 05. 2026 */}}
{{/* Time-stamp: <2026-05-08 11:35:15 krylon> */}}
<!DOCTYPE html>
<html>
  {{ template "head" . }}

  <body>
    {{ template "intro" . }}

    <hr />

    <h2>{{ fmt_date .Period.Begin }} to {{ fmt_date .Period.End }}</h2>

    <table class="table table-striped">
      <thead>
        <tr>
          <th>Word</th>
          <th>#</th>
      </tr>
      </thead>

      <tbody>
        {{ range .Words }}
        <tr>
          <td>{{ .Word }}</td>
          <td>{{ fmt_float .Count }}</td>
        </tr>
        {{ end }}
      </tbody>
    </table>

    {{ template "footer" . }}
  </body>
</html>
{{ end }}
