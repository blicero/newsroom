{{ define "tags" }}
{{/* Created on 07. 04. 2026 */}}
{{/* Time-stamp: <2026-04-18 22:08:26 krylon> */}}
<!DOCTYPE html>
<html>
  {{ template "head" . }}

  <body>
    {{ template "intro" . }}

    <div>
      {{ template "tag_form" . }}
    </div>

    <hr />

    <div>
      <script>
       function edit_tag(tag_id, parent_id, name) {
               const msg = `Edit Tag ${name} (${tag_id} &lt; ${parent_id})`
               console.log(msg)
               msg_add(msg, 'INFO')

               $("#tag_id")[0].value = tag_id
               $("#tag_parent")[0].value = parent_id
               $("#tag_name")[0].value = name
       }
      </script>
      <table class="table table-primary table-sm table-striped">
        <thead>
          <tr>
            <th>ID</th>
            <th>Parent</th>
            <th>Name</th>
          </tr>
        </thead>

        <tbody>
          {{ range .Tags }}
          <tr>
            <td>{{ .ID }}</td>
            <td>{{ .Parent }}</td>
            <td>
              {{ nbsp (twice .Level) }}
              {{ .Name }}
              <button type="button"
                class="btn btn-success btn-sm"
                onclick="edit_tag({{ .ID }}, {{ .ParentID }}, '{{ .Name }}');">
                <small>Edit</small>
              </button>
            </td>
          </tr>
          {{ end }}
        </tbody>
      </table>
    </div>

    <hr>

    <div>
      <!-- Display Items here? -->
    </div>

    {{ template "footer" . }}
  </body>
</html>
{{ end }}
