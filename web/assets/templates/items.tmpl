{{ define "items" }}
{{/* Created on 12. 03. 2026 */}}
{{/* Time-stamp: <2026-03-31 14:28:45 krylon> */}}
{{ $feeds := .Feeds }}
{{ range .Items }}
<tr id="item_row_{{ .ID }}"
    {{- if .IsBoring }}class="boring"{{ end }}>
    <td>{{ fmt_time_minute .Timestamp }}</td>
    <td>
        <a href="/feed/{{ .FeedID }}">
            {{ (index $feeds .FeedID).Name }}
        </a>
    </td>
    <td>
        <a href="{{ .URL }}" target="_blank">
            {{ .Title }}
        </a>
    </td>
    <td id="item_rating_{{ .ID }}"> {{/* Rating */}}
        {{ if (not .IsRated) }}
        <small><i>({{ .EffectiveRating }})</i></small>
        <button type="button"
                class="btn btn-primary btn-sm"
                onclick="rate_item({{ .ID }}, 2);">
            Interesting
        </button>
        <button type="button"
                class="btn btn-secondary btn-sm"
                onclick="rate_item({{ .ID }}, 1);">
            Boring
        </button>
        {{ else if .IsBoring }}
        <img src="/static/face-tired.png" onclick="unrate_item({{ .ID }});" />
        {{ else }}
        <img src="/static/face-glasses.png" onclick="unrate_item({{ .ID }});" />
        {{ end }}
    </td>
    <td> {{/* Tags */}}
        &nbsp;
    </td>
    <td>
        <button class="btn btn-primary"
                data-bs-toggle="collapse"
                href="#collapse_item_{{ .ID }}"
                aria-expanded="false"
                aria-controls="#collapse_item_{{ .ID }}">
            Description
        </button>
        <div class="collapse" id="collapse_item_{{ .ID }}">
            {{ .Body }}
        </div>
    </td>
</tr>
{{ end }}
{{ end }}
